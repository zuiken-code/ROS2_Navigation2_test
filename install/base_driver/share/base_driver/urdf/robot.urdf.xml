<?xml version="1.0"?>
<robot name="my_robot">

  <!-- base_footprint: 地面基準 -->
  <link name="base_footprint"/>

  <!-- base_link: ロボット中心 -->
  <link name="base_link">
    <visual>
      <geometry><box size="0.15 0.10 0.04"/></geometry>
      <origin xyz="0 0 0.02"/>
    </visual>
    <collision>
      <geometry><box size="0.15 0.10 0.04"/></geometry>
      <origin xyz="0 0 0.02"/>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>
  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 0"/>
  </joint>

  <!-- 左車輪 -->
  <link name="left_wheel">
    <visual>
      <geometry><cylinder radius="0.030" length="0.020"/></geometry>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00001" iyy="0.00001" izz="0.00001"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="left_wheel"/>
    <origin xyz="0.0 0.065 0.0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- 右車輪 -->
  <link name="right_wheel">
    <visual>
      <geometry><cylinder radius="0.030" length="0.020"/></geometry>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00001" iyy="0.00001" izz="0.00001"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="right_wheel"/>
    <origin xyz="0.0 -0.065 0.0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- 超音波センサーフレーム（前方） -->
  <link name="laser_frame"/>
  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="laser_frame"/>
    <origin xyz="0.07 0.0 0.03" rpy="0 0 0"/>
  </joint>

</robot>